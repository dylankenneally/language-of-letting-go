---
layout: base.njk
---
{% set firstMeditation = collections.meditations[0] %}

<div id="current-meditation">
  {% from "meditation-content.njk" import meditationContent %}
  {{ meditationContent(
      firstMeditation.data.title,
      firstMeditation.data.displayDate,
      firstMeditation.content,
      "today-meditation-title",
      "today-meditation-date",
      "today-meditation-content"
    )
  }}

  <section class="calendar-section" aria-label="Pick a Date">
    <div id="meditation-calendar" class="meditation-calendar"></div>
  </section>
</div>

<script id="meditations-data" type="application/json">
[
  {% for meditation in collections.meditations %}
    {
      "id": {{ meditation.fileSlug | dump | safe }},
      "title": {{ meditation.data.title | dump | safe }},
      "displayDate": {{ meditation.data.displayDate | dump | safe }},
      "url": {{ (meditation.url | url) | dump | safe }},
      "content": {{ meditation.content | dump | safe }}
    }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

<template id="missing-meditation-template">
  {% include "not-found-content.njk" %}
</template>

{% include "meditation-calendar-script.njk" %}
<script>
  const meditationDataNode = document.getElementById("meditations-data");

  if (meditationDataNode) {
    const titleNode = document.getElementById("today-meditation-title");
    const dateNode = document.getElementById("today-meditation-date");
    const contentNode = document.getElementById("today-meditation-content");
    const missingMeditationTemplate = document.getElementById("missing-meditation-template");
    const now = new Date();
    const month = String(now.getMonth() + 1).padStart(2, "0");
    const day = String(now.getDate()).padStart(2, "0");
    const todayId = `${month}.${day}`;
    const initialUrl = new URL(window.location.href);
    const meditationCalendar = window.createMeditationCalendar({
      dataNodeId: "meditations-data",
      currentMeditationId: todayId,
      onSelectMeditation(selectedMeditation) {
        setFeaturedMeditation(selectedMeditation);
        updateHistoryForMeditation(selectedMeditation);
      }
    });

    if (meditationCalendar) {
      const { meditations, meditationsById, syncSelection } = meditationCalendar;
      const todaysMeditation = meditationsById.get(todayId);
      const defaultMeditation = todaysMeditation || meditations[0];

      function getRequestedMeditationState() {
        const meditationId = new URL(window.location.href).searchParams.get("date");
        if (!meditationId) {
          return { meditation: null, invalidDateParam: false };
        }

        const meditation = meditationsById.get(meditationId) || null;

        return {
          meditation,
          invalidDateParam: !meditation
        };
      }

      function getNotFoundMeditationView() {
        return {
          id: null,
          title: "{{ site.notFound }}",
          displayDate: "",
          content: missingMeditationTemplate ? missingMeditationTemplate.innerHTML : ""
        };
      }

      function getCurrentMeditationView() {
        const requestedState = getRequestedMeditationState();
        if (requestedState.invalidDateParam) {
          return getNotFoundMeditationView();
        }

        return requestedState.meditation || defaultMeditation;
      }

      const initialMeditation = getCurrentMeditationView();

      function setFeaturedMeditation(meditation) {
        if (!meditation || !titleNode || !dateNode || !contentNode) {
          return;
        }

        dateNode.textContent = meditation.displayDate;
        dateNode.hidden = !meditation.displayDate;
        titleNode.textContent = meditation.title;
        contentNode.innerHTML = meditation.content;
      }

      function getUrlForMeditation(meditationId) {
        const nextUrl = new URL(window.location.href);

        if (meditationId === todayId) {
          nextUrl.searchParams.delete("date");
        } else {
          nextUrl.searchParams.set("date", meditationId);
        }

        return nextUrl;
      }

      function updateHistoryForMeditation(meditation) {
        const nextUrl = getUrlForMeditation(meditation.id);
        const nextPath = `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`;
        window.history.pushState({ meditationId: meditation.id }, "", nextPath);
      }

      setFeaturedMeditation(initialMeditation);
      syncSelection(initialMeditation.id);

      window.addEventListener("popstate", () => {
        const meditation = getCurrentMeditationView();
        setFeaturedMeditation(meditation);
        syncSelection(meditation.id);
      });

      if (!initialUrl.searchParams.get("date") && initialMeditation.id !== todayId) {
        const nextUrl = getUrlForMeditation(initialMeditation.id);
        window.history.replaceState(
          { meditationId: initialMeditation.id },
          "",
          `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`
        );
      }
    }
  }
</script>
