<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set isNotFoundPage = page and page.url == "/404.html" %}
    {% set isHomePage = page and page.url == "/" %}
    <meta name="robots" content="{% if isNotFoundPage %}noindex, follow{% else %}index, follow{% endif %}">
    {% if site.url and page and page.url and not isNotFoundPage %}
      <link rel="canonical" href="{{ site.url }}{{ page.url | url }}">
      <meta property="og:url" content="{{ site.url }}{{ page.url | url }}">
    {% endif %}
    {% if title %}
      <title>{{ title }} | {{ site.title }}</title>
    {% else %}
      <title>{{ site.title }} | {{ site.description }}</title>
    {% endif %}
    <link rel="stylesheet" href="{{ '/vanilla-calendar-pro/styles/layout.css' | url }}">
    <link rel="stylesheet" href="{{ '/vanilla-calendar-pro/styles/themes/light.css' | url }}">
    <style>
      @font-face {
        font-family: "BBC Reith Sans";
        src: url("{{ '/fonts/BBCReithSans400.woff2' | url }}") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "BBC Reith Sans";
        src: url("{{ '/fonts/BBCReithSans700.woff2' | url }}") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "BBC Reith Serif";
        src: url("{{ '/fonts/BBCReithSerif400.woff2' | url }}") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "BBC Reith Serif";
        src: url("{{ '/fonts/BBCReithSerif400Italic.woff2' | url }}") format("woff2");
        font-weight: 400;
        font-style: italic;
        font-display: swap;
      }

      @font-face {
        font-family: "BBC Reith Serif";
        src: url("{{ '/fonts/BBCReithSerif700.woff2' | url }}") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      :root {
        color-scheme: light;
        --bg: #f6f1e8;
        --paper: #fffdf8;
        --ink: #1f2933;
        --muted: #6b7280;
        --accent: #235347;
        --border: #ded6c8;
        --font-sans: "BBC Reith Sans", system-ui, sans-serif;
        --font-serif: "BBC Reith Serif", Georgia, "Times New Roman", serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--ink);
      }

      a {
        color: var(--accent);
      }

      .shell {
        width: min(100%, 72rem);
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
      }

      .card {
        background: var(--paper);
        border: 1px solid var(--border);
        border-radius: 1.25rem;
        box-shadow: 0 1rem 3rem rgba(31, 41, 51, 0.08);
      }

      .site-header {
        margin-bottom: 2rem;
        padding: 1.5rem;
      }

      .site-header h1,
      .site-header .site-title,
      .site-header p {
        margin: 0;
      }

      .site-header h1,
      .site-header .site-title {
        font-family: var(--font-serif);
        font-weight: 700;
        font-size: 2rem;
      }

      .site-header p {
        margin-top: 0.75rem;
        color: var(--muted);
        font-family: var(--font-sans);
      }

      .content {
        padding: 1.5rem;
      }

      .calendar-section {
        margin-top: 1.5rem;
      }

      .vc {
        border: 1px solid var(--border);
        border-radius: 1rem;
      }

      .vc-wrapper * {
        font-family: var(--font-sans);
      }

      .vc [data-vc="calendar"] {
        width: 100%;
        max-width: 100%;
        padding: 0;
        background: transparent;
        color: var(--ink);
      }

      .vc [data-vc="column"] {
        min-width: 0;
      }

      .vc [data-vc="month"],
      .vc [data-vc="year"] {
        font-family: var(--font-serif);
      }

      .vc [data-vc="week"] {
        margin-bottom: 0.65rem;
      }

      .vc [data-vc-theme="light"].vc,
      .vc [data-vc-theme="light"] .vc-month,
      .vc [data-vc-theme="light"] .vc-year,
      .vc [data-vc-theme="light"] .vc-header__content {
        color: var(--ink);
      }

      .vc [data-vc-theme="light"].vc [tabindex="0"]:focus-visible,
      .vc [data-vc-theme="light"].vc button:focus-visible,
      .vc [data-vc-theme="light"].vc:focus-visible {
        outline-color: rgba(35, 83, 71, 0.45);
      }

      .vc [data-vc-theme="light"] .vc-month:hover,
      .vc [data-vc-theme="light"] .vc-year:hover,
      .vc [data-vc-theme="light"] .vc-week__day,
      .vc [data-vc-theme="light"] .vc-week-number,
      .vc [data-vc-theme="light"] .vc-week-numbers__title {
        color: var(--muted);
      }

      .vc [data-vc-theme="light"] .vc-date__btn:hover,
      .vc [data-vc-theme="light"] .vc-date[data-vc-date-today] .vc-date__btn {
        background: rgba(35, 83, 71, 0.08);
        color: var(--ink);
      }

      .vc [data-vc-theme="light"] .vc-date[data-vc-date-selected] .vc-date__btn,
      .vc [data-vc-theme="light"] .vc-date[data-vc-date-selected=middle] .vc-date__btn,
      .vc [data-vc-theme="light"] .vc-months__month[data-vc-months-month-selected],
      .vc [data-vc-theme="light"] .vc-years__year[data-vc-years-year-selected] {
        background: var(--accent);
        color: #fff;
      }

      .vc [data-vc-theme="light"] .vc-arrow:before {
        opacity: 0.9;
      }

      .vc [data-vc-theme="light"] .vc-date[data-vc-date-disabled] .vc-date__btn {
        color: #a3acb7;
      }

      .quote,
      .focal-point {
        display: block;
        margin: 0;
        font-family: var(--font-serif);
        font-style: italic;
      }

      .quote blockquote {
        margin: 0;
        padding: 0;
      }

      .quote blockquote em,
      .focal-point em {
        font-style: normal;
      }

      .quote {
        padding: 1rem 2.5rem;
      }

      .focal-point {
        margin-top: 1rem;
      }

      .quote-attribution {
        display: block;
        margin-top: 0.75rem;
        color: var(--muted);
        font-family: var(--font-serif);
        text-transform: uppercase;
        font-style: normal;
        font-size: .9rem;
        text-align: right;
      }

      .quote-attribution::before {
        {# em-dash inserted before the attribution #}
        content: "\2014";
      }

      .prose {
        line-height: 1.625;
        font-size: 1.1rem;
        font-family: var(--font-serif);
      }

      .meditation-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        font-size: 1.1em;
        font-family: var(--font-serif);
        font-weight: 700;
      }

      .meditation-header h1,
      .meditation-header h2,
      .meditation-header .date {
        margin: 0;
        margin-bottom: 1rem;
      }

      .meditation-header .date {
        font-style: italic;
      }

      #current-meditation {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        gap: 2rem;
      }

      @media screen and (max-width: 599px) {
        .prose {
          font-size: 1rem;
        }

        .meditation-header {
          font-size: 1em;
        }

        .calendar-section {
          padding: 1rem;
        }
      }

      @media screen and (max-width: 999px) {
        #current-meditation {
          flex-wrap: wrap;
          gap: unset;
        }
      }

      .prose p {
        margin-bottom: 0.125rem;
        margin-top: 0rem;
      }

      .prose p + p {
        text-indent: 2rem;
      }

      .back-link {
        display: inline-block;
        margin-bottom: 1rem;
      }

      .meditation-nav {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
      }

      .meditation-nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.75rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .meditation-nav-link {
        display: inline-flex;
        align-items: center;
        min-height: 2.75rem;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.8);
        text-decoration: none;
      }

      .meditation-nav-link:hover {
        background: #fff;
      }

      .meditation-nav-link.secondary {
        color: var(--muted);
        border-style: dashed;
        background: transparent;
        opacity: 0.8;
      }

      .meditation-nav-link-next {
        margin-left: auto;
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="site-header card">
        {% if isHomePage %}
          <h1><a href="{{ '/' | url }}" style="text-decoration: none; color: inherit;">{{ site.title }}</a></h1>
        {% else %}
          <div class="site-title"><a href="{{ '/' | url }}" style="text-decoration: none; color: inherit;">{{ site.title }}</a></div>
        {% endif %}
        <p>{{ site.description }}</p>
      </header>
      <div class="content card">
        {{ content | safe }}
      </div>
    </main>
  </body>
</html>
