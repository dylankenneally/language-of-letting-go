<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set isNotFoundPage = page and page.url == "/404.html" %}
    {% set isHomePage = page and page.url == "/" %}
    {% set isIndexPage = page and page.url == "/index/" %}
    {% set isAboutPage = page and page.url == "/about/" %}
    {% set isSearchPage = page and page.url == "/search/" %}
    {% set pageTitle = (title ~ " | " ~ site.title) if title else (site.title ~ " | " ~ site.description) %}
    {% set pageDescription = description if description else site.description %}
    {% set escapedPageTitle = pageTitle | replace("&", "&amp;") | replace("\"", "&quot;") | replace("<", "&lt;") | replace(">", "&gt;") %}
    {% set escapedPageDescription = pageDescription | replace("&", "&amp;") | replace("\"", "&quot;") | replace("<", "&lt;") | replace(">", "&gt;") %}
    {% set escapedSiteTitle = site.title | replace("&", "&amp;") | replace("\"", "&quot;") | replace("<", "&lt;") | replace(">", "&gt;") %}
    <meta name="robots" content="{% if isNotFoundPage %}noindex, follow{% else %}index, follow{% endif %}">
    {% if site.url and page and page.url and not isNotFoundPage %}
      <link rel="canonical" href="{{ site.url }}{{ page.url | url }}">
      <meta property="og:url" content="{{ site.url }}{{ page.url | url }}">
    {% endif %}
    <title>{{ escapedPageTitle }}</title>
    <meta name="description" content="{{ escapedPageDescription }}">
    <meta property="og:title" content="{{ escapedPageTitle }}">
    <meta property="og:description" content="{{ escapedPageDescription }}">
    <meta property="og:type" content="{% if isHomePage %}website{% else %}article{% endif %}">
    <meta property="og:site_name" content="{{ escapedSiteTitle }}">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ escapedPageTitle }}">
    <meta name="twitter:description" content="{{ escapedPageDescription }}">
    <link rel="stylesheet" href="{{ '/vanilla-calendar-pro/styles/layout.css' | url }}">
    <link rel="stylesheet" href="{{ '/vanilla-calendar-pro/styles/themes/light.css' | url }}">

    {# favicons #}
    {# Classic favicon #}
    <link rel="icon" type="image/x-icon"   href="{{ '/favicon.ico' | url }}">
    <link rel="shortcut icon" href="{{ '/favicon.ico' | url }}" />
    <link rel="icon" type="image/svg+xml"  href="{{ '/favicon.svg' | url }}">
    <link rel="icon" type="image/png" sizes="96x96"  href="{{ '/favicon-96x96.png' | url }}">
    <link rel="icon" type="image/png" sizes="64x64"  href="{{ '/favicon-64x64.png' | url }}">
    <link rel="icon" type="image/png" sizes="32x32"  href="{{ '/favicon-32x32.png' | url }}">
    <link rel="icon" type="image/png" sizes="16x16"  href="{{ '/favicon-16x16.png' | url }}">

    {# Apple Touch Icons #}
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/apple-touch-icon.png' | url }}">
    <meta name="apple-mobile-web-app-title" content="{{ site.shortTitle }}" />

    {# Android / PWA #}
    <link rel="manifest" href="{{ '/site.webmanifest' | url }}">

    {# Windows tiles #}
    {# todo: color from css #}
    <meta name="msapplication-TileColor"   content="#2d5248">
    <meta name="msapplication-config"      content="{{ '/browserconfig.xml' | url }}">

    {# Theme colour (Chrome on Android address bar, Safari pinned tabs) #}
    {# todo: color from css #}
    <meta name="theme-color" content="#2d5248">

    <style>
      @font-face {
        font-family: "BBC Reith Sans";
        src: url("{{ '/fonts/BBCReithSans400.woff2' | url }}") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "BBC Reith Serif";
        src: url("{{ '/fonts/BBCReithSerif400.woff2' | url }}") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "BBC Reith Serif";
        src: url("{{ '/fonts/BBCReithSerif400Italic.woff2' | url }}") format("woff2");
        font-weight: 400;
        font-style: italic;
        font-display: swap;
      }

      @font-face {
        font-family: "BBC Reith Serif";
        src: url("{{ '/fonts/BBCReithSerif700.woff2' | url }}") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      :root {
        color-scheme: light;
        --font-sans: "BBC Reith Sans", system-ui, sans-serif;
        --font-serif: "BBC Reith Serif", Georgia, "Times New Roman", serif;
        /* https://www.canva.com/colors/color-wheel/ */
        --paper: #fffdf8;
        --button-bg: rgba(255, 255, 255, 0.8);
        --button-bg-a11y: rgba(255, 255, 255);
        --muted: #6b7280;
        --ink: #0b0b0b;
        --border-colour: #ded6c8;
        --button-bd-disabled: rgba(31, 41, 51, 0.035);
        --button-text-disabled: rgba(107, 114, 128, 0.25);
        --border-colour-disabled: rgba(222, 214, 200, 0.9);
        --associated: rgba(31, 41, 51, 0.3);
        --primary: #2d5248;
        --secondary: #7fb9a9;
        --border: 1px solid var(--border-colour);
      }

      * {
        box-sizing: border-box;
      }

      /* @link https://utopia.fyi/type/calculator?c=360,17,1.18,1240,20,1.25,3,2,&s=0.75,1.5|2|3|4|6,s-l&g=s,l,xl,12 */
      :root {
        /* Step -2: 12.2091px → 12.8px */
        --typography--2: clamp(0.7631rem, 0.748rem + 0.0671vw, 0.8rem);
        /* Step -1: 14.4068px → 16px */
        --typography--1: clamp(0.9004rem, 0.8597rem + 0.181vw, 1rem);
        /* Step 0: 17px → 20px */
        --typography-0: clamp(1.0625rem, 0.9858rem + 0.3409vw, 1.25rem);
        /* Step 1: 20.06px → 25px */
        --typography-1: clamp(1.2538rem, 1.1274rem + 0.5614vw, 1.5625rem);
        /* Step 2: 23.6708px → 31.25px */
        --typography-2: clamp(1.4794rem, 1.2856rem + 0.8613vw, 1.9531rem);
        /* Step 3: 27.9315px → 39.0625px */
        --typography-3: clamp(1.7457rem, 1.4611rem + 1.2649vw, 2.4414rem);
      }

      html {
        font-size: 16px;
      }

      body {
        font-family: var(--font-serif);
        width: min(100%, 72rem);
        margin: 0 auto;
        padding: .25rem;

        background: var(--paper);
        color: var(--ink);
      }

      h1, h2, h3 {
        text-wrap: balance;
      }

      .prose {
        text-wrap: pretty;
      }

      h1 {
        font-size: var(--typography-3);
      }

      h2 {
        font-size: var(--typography-2);
      }

      h3 {
        font-size: var(--typography-1);
      }

      .prose,
      .meditation-index-list {
        font-size: var(--typography-0);
      }

      .site-description,
      .action-button,
      .is-disabled,
      .quote-attribution {
        font-size: var(--typography--1);
      }

      .search-form,
      .meditation-header time,
      .site-footer,
      .about-footer {
        font-size: var(--typography--2);
      }

      a {
        color: var(--ink);
        text-decoration: none;
      }

      .meditation-nav-link-next,
      .site-footer a {
        color: var(--muted);
        text-decoration: none;
      }

      .action-button,
      .action-button a {
        color: var(--muted);
        background: var(--button-bg);
        border: var(--border);
        font-family: var(--font-sans);
      }

      .action-button:hover,
      .action-button:focus-visible {
        background: var(--primary);
        color: var(--button-bg-a11y);
      }

      a:hover,
      a:focus-visible,
      .action-button:hover,
      .action-button:focus-visible  {
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.16em;
      }

      h1 a {
        color: inherit;
      }

      h1 a:hover,
      h1 a:focus-visible,
      h2 a:hover,
      h2 a:focus-visible {
        text-decoration-thickness: 2px;
      }

      .is-disabled {
        border: var(--border);
        background: var(--button-bd-disabled);
        color: var(--button-text-disabled);
        cursor: not-allowed;
      }


      .skip-link {
        background: var(--button-bg-a11y);

        position: absolute;
        left: 0.5rem;
        top: 0.5rem;
        transform: translateY(-140%);
        padding: 0.75rem 1rem;
        border-radius: 0 0 0.5rem 0.5rem;
        border-radius: 0.5rem;
        border-radius: 999px;
        text-decoration: none;
        z-index: 1000;
      }

      .skip-link:focus,
      .skip-link:focus-visible {
        transform: translateY(0);
      }

      .site-header {
        margin-bottom: .5rem;
        padding: 1.5rem;
      }

      .site-header h1,
      .site-header p {
        margin: 0;
      }

      .site-description {
        color: var(--muted);
        font-family: var(--font-sans);
      }

      p.site-description {
        margin-top: 0.75rem;
        margin-top: .5rem;
      }

      .calendar-section {
        margin-top: 1.5rem;
      }

      .vc {
        border: var(--border);
        border-radius: 1rem;
      }

      .vc-wrapper * {
        font-family: var(--font-sans);
      }

      .vc [data-vc="calendar"] {
        width: 100%;
        max-width: 100%;
        padding: 0;
      }

      .vc [data-vc="column"] {
        min-width: 0;
      }

      .vc [data-vc="month"],
      .vc [data-vc="year"] {
        font-family: var(--font-serif);
      }

      .vc [data-vc="week"] {
        margin-bottom: 0.65rem;
      }

      [data-vc-theme="light"].vc {
        background: var(--button-bg);
        color: var(--ink);
      }

      [data-vc-theme="light"].vc [tabindex="0"]:focus-visible,
      [data-vc-theme="light"].vc button:focus-visible,
      [data-vc-theme="light"].vc:focus-visible {
        outline-color: unset;
      }

      [data-vc-theme="light"] .vc-month:hover,
      [data-vc-theme="light"] .vc-year:hover,
      [data-vc-theme="light"] .vc-week__day,
      [data-vc-theme="light"] .vc-week-number,
      [data-vc-theme="light"] .vc-week-numbers__title {
        color: var(--muted);
      }

      [data-vc-theme="light"] .vc-date__btn:hover,
      [data-vc-theme="light"] .vc-date[data-vc-date-today] .vc-date__btn,
      [data-vc-theme=light] .vc-years__year[data-vc-years-year-selected]:hover {
        background: var(--primary);
        color: var(--button-bg-a11y);
      }

      [data-vc-theme=light] .vc-date__btn {
        color: var(--ink);
      }

      [data-vc-theme="light"] .vc-date[data-vc-date-selected] .vc-date__btn,
      [data-vc-theme="light"] .vc-date[data-vc-date-selected=middle] .vc-date__btn,
      [data-vc-theme="light"] .vc-months__month[data-vc-months-month-selected],
      [data-vc-theme="light"] .vc-years__year[data-vc-years-year-selected] {
        background: var(--secondary);
      }

      [data-vc-theme=light] .vc-date[data-vc-date-selected] .vc-date__btn:hover,
      [data-vc-theme=light] .vc-months__month[data-vc-months-month-selected]:hover,
      [data-vc-theme=light] .vc-months__month:hover,
      [data-vc-theme=light] .vc-years__year:hover {
        background: var(--primary);
        color: var(--button-bg-a11y);
      }

      [data-vc-theme=light] .vc-date[data-vc-date-month=next] .vc-date__btn {
        color: var(--muted);
      }

      [data-vc-theme=light] .vc-date[data-vc-date-month=next] .vc-date__btn:hover,
      [data-vc-theme=light] .vc-months__month:hover {
        color: var(--button-bg-a11y);
      }

      .vc [data-vc-theme="light"] .vc-arrow:before {
        opacity: 0.9;
      }

      .quote,
      .focal-point {
        display: block;
        margin: 0;
        font-style: italic;
      }

      .quote blockquote {
        margin: 0;
        padding: 0;
      }

      .quote blockquote em,
      .focal-point em {
        font-style: normal;
      }

      .quote {
        padding: 1rem 2.5rem;
      }

      .focal-point {
        margin-top: 1rem;
      }

      .quote-attribution,
      .meditation-header time {
        color: var(--muted);
        font-family: var(--font-sans);
      }

      .quote-attribution {
        display: block;
        margin-top: 0.75rem;
        text-transform: uppercase;
        font-style: normal;
        text-align: right;
      }

      .quote-attribution::before {
        {# em-dash inserted before the attribution #}
        content: "\2014";
      }

      .prose {
        line-height: 1.625;
      }

      .meditation-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
      }

      .meditation-header h1,
      .meditation-header h2,
      .meditation-header time,
      .meditation-index-header h1,
      .meditation-index-header h2 {
        margin: 0;
        margin-bottom: 1rem;
      }

      #current-meditation {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        gap: 2rem;
      }

      @media screen and (max-width: 599px) {
        .calendar-section {
          padding: 1rem;
        }
      }

      @media screen and (max-width: 999px) {
        #current-meditation {
          flex-wrap: wrap;
          gap: unset;
        }
      }

      .prose p {
        margin-bottom: 0.125rem;
        margin-top: 0rem;
      }

      .prose p + p {
        text-indent: 2rem;
      }

      .back-link {
        display: inline-block;
        margin-bottom: 1rem;
      }

      .meditation-nav {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: var(--border);
      }

      .meditation-nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.75rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .meditation-nav-link {
        display: inline-flex;
        align-items: center;
        min-height: 2.75rem;
        padding: 0.75rem 1rem;
        border: var(--border);
        border-radius: 999px;
      }

      .meditation-nav-link-next {
        margin-left: auto;
      }

      .site-footer {
        margin-top: .5rem;
        font-family: var(--font-sans);
      }

      .corp-logo {
        height: .9rem;
      }

      .site-footer > nav {
        display: flex;
        flex-direction: row;
        justify-content: space-evenly;
        align-items: baseline;
        flex-wrap: wrap;
        gap: .5rem;
      }

      a.nav-current-page {
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.16em;
      }
    </style>
  </head>
  <body>
    {# todo: review this UX on skip link #}
    <a class="action-button skip-link" href="#main-content">{{ site.skipToMain }}</a>

    <header class="site-header" id="top">
      <h1><a href="{{ '/' | url }}">{{ site.title }}</a></h1>
      <p class="site-description">{{ site.description }}</p>
      {% if not isSearchPage %}
        {% include "search-component.njk" %}
      {% endif %}
    </header>

    <main id="main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <nav aria-label="{{ site.primaryNav }}">
        <a href="{{ '/' | url }}"{% if isHomePage %} class="nav-current-page"{% endif %}>{{ site.home }}</a>
        <a href="{{ '/about/' | url }}"{% if isAboutPage %} class="nav-current-page"{% endif %}>{{ site.about }}</a>
        <a href="{{ '/index/' | url }}"{% if isIndexPage %} class="nav-current-page"{% endif %}>{{ site.seeAll }}</a>
        <a href="{{ '/search/' | url }}"{% if isSearchPage %} class="nav-current-page"{% endif %}>{{ site.search }}</a>
        <span>
          <a href="{{ site.externalUrls.gitHub }}" target="_blank" rel="noopener">
            <img class="corp-logo" src="{{ '/images/github.svg' | url }}" alt="">
            Open Source
          </a>
        </span>
        <span>
          <a href="{{ site.externalUrls.amazon }}" target="_blank" rel="noopener">
            <img class="corp-logo" src="{{ '/images/amazon.svg' | url }}" alt="">
            Buy the book
          </a>
        </span>
      </nav>
    </footer>

    {% include "back-to-top-btn.njk" %}
  </body>
</html>
