---
layout: base.njk
---
{% from "meditation-content.njk" import meditationContent %}

<div id="current-meditation">
  {{ meditationContent(title, displayDate, content) }}

  <section class="calendar-section" aria-label="Pick a Date">
    <div id="meditation-calendar" class="meditation-calendar"></div>
  </section>
</div>

<nav class="meditation-nav" aria-label="Adjacent meditations" data-current-meditation="{{ page.fileSlug }}">
  <div class="meditation-nav-group">
    <div class="meditation-nav-links" id="previous-meditation-links"></div>
  </div>
  <div class="meditation-nav-group">
    <div class="meditation-nav-links" id="next-meditation-links"></div>
  </div>
</nav>

<script id="meditation-nav-data" type="application/json">
[
  {% for meditation in collections.meditations %}
    {
      "id": {{ meditation.fileSlug | dump | safe }},
      "displayDate": {{ meditation.data.displayDate | dump | safe }},
      "url": {{ (meditation.url | url) | dump | safe }}
    }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

{% include "meditation-calendar-script.njk" %}
{% include "adjacent-meditation-nav-script.njk" %}
<script>
  function initMeditationCalendar() {
    const navRoot = document.querySelector("[data-current-meditation]");
    if (!navRoot || !window.createMeditationCalendar) {
      return;
    }

    window.createMeditationCalendar({
      dataNodeId: "meditation-nav-data",
      currentMeditationId: navRoot.dataset.currentMeditation,
      onSelectMeditation(selectedMeditation) {
        window.location.href = selectedMeditation.url;
      }
    });
  }

  initMeditationCalendar();
  const adjacentMeditationNav = window.createAdjacentMeditationNav({
    dataNodeId: "meditation-nav-data",
    currentMeditationId: "{{ page.fileSlug }}"
  });

  if (adjacentMeditationNav) {
    adjacentMeditationNav.update();
  }
</script>
