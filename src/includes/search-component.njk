<style>
  .search-form {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 0.5rem;
  }

  .search-form input[type="search"] {
    width: min(16rem, 55vw);
    border: var(--border);
    border-radius: 999px;
    flex: 1 1 18rem;
    min-height: 2.75rem;
    padding: 0.65rem 0.9rem;
    font: inherit;
  }

  .search-form input::placeholder {
    text-align: right;
    color: var(--muted);
  }

  .search-form button {
    min-height: 2.75rem;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    font: inherit;
    cursor: pointer;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<form
  id="search-form"
  class="search-form"
  role="search"
  action="{{ '/search/' | url }}"
  method="get"
>
  <label for="search-query" class="visually-hidden">{{ site.search }}</label>
  <input
    id="search-query"
    name="q"
    type="search"
    required
    placeholder="{{ site.search }}"
    data-search-placeholder-base="{{ site.search }}"
  >
  <button type="submit" class="action-button">{{ site.search }}</button>
</form>

<script>
  // Adds the keyboard shortcut for "⌘K" / "Ctrl+K" if appropriate
  (function () {
    const hasKeyboard = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const isMac = navigator.userAgentData?.platform === "macOS" || /Mac/i.test(navigator.platform);

    function applySearchPlaceholder(input) {
      if (!input || !hasKeyboard) {
        return;
      }

      input.placeholder = isMac ? "⌘K" : "Ctrl+K";
      input.setAttribute("aria-keyshortcuts", isMac ? "Meta+K" : "Control+K");
    }

    const searchInput = document.getElementById("search-query");
    applySearchPlaceholder(searchInput);

    document.addEventListener("keydown", (event) => {
      const usesShortcutModifier = isMac ? event.metaKey : event.ctrlKey;
      if (!usesShortcutModifier || event.key.toLowerCase() !== "k" || event.altKey) {
        return;
      }

      event.preventDefault();
      searchInput.focus();
      if (typeof searchInput.select === "function") {
        searchInput.select();
      }
    });
  })();
</script>
